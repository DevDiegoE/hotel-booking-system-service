{
    "entryFile": "src/app.ts",
    "noImplicitAdditionalProperties": "throw-on-extras",
    "controllerPathGlobs": [
        "src/infrastructure/express/controllers/*.ts"
    ],
    "spec": {
        "outputDirectory": "src/infrastructure/express/docs",
        "specVersion": 3,
        "basePath": "/api",
        "title": "Hotel Booking API",
        "version": "1.0.0"
    },
    "routes": {
        "routesDir": "src/infrastructure/express/routes",
        "middlewareTemplate": "tsoa-template"
    }
}